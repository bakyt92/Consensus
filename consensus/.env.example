# Copy to .env.local and fill in the secrets. See CLAUDE.md > Environment.

# --- Required ---
OPENAI_API_KEY=
AUTH_SECRET=replace-me-with-something-long
DATABASE_URL=file:./dev.db
APP_ORIGIN=http://localhost:3000

# --- Optional ---
OPENAI_MODEL=gpt-4o-mini

# Email (magic links). If unset, links are printed to the server console.
RESEND_API_KEY=
RESEND_FROM=

# --- Voice / classifier integrations ---
# Each is optional. When unset, the corresponding adapter runs in stub mode
# (see src/server/integrations/{slng,gradium,pioneer}.ts).

# SLNG — diarized STT for the mediator's mic input.
SLNG_API_KEY=
SLNG_API_URL=

# Gradium — TTS for the mediator's voice replies.
GRADIUM_API_KEY=
GRADIUM_API_URL=

# Pioneer — fast on-topic / consensus-delta classifier. When unset, every
# message reaches OpenAI (no two-tier savings). Set PIONEER_STUB_FILTER=1 to
# make the stub filter any message containing "spam" for testing.
PIONEER_API_KEY=
PIONEER_API_URL=
PIONEER_STUB_FILTER=0
